@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Urx CONFIG REQUIRED)

if(@BINARY_DISTRIB@)
  set(UAC_MATLAB_INSTALL_DATADIR
      "@CPACK_PACKAGING_INSTALL_PREFIX@/@UAC_MATLAB_INSTALL_DATADIR@")
else()
  set(UAC_MATLAB_INSTALL_DATADIR
      "@CMAKE_INSTALL_PREFIX@/@UAC_MATLAB_INSTALL_DATADIR@")
endif()

include("${CMAKE_CURRENT_LIST_DIR}/UacTargets.cmake")

check_required_components(Uac)
